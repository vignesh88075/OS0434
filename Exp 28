#include <stdio.h>
#include <string.h>

int main()
{
    char text[10][200];
    char keyword[50];
    int lines;

    printf("------ GREP COMMAND SIMULATION ------\n");

    printf("Enter number of lines: ");
    scanf("%d", &lines);

    printf("Enter the text lines:\n");

    for(int i = 0; i < lines; i++)
    {
        scanf(" %[^\n]", text[i]);
    }

    printf("Enter word to search: ");
    scanf("%s", keyword);

    printf("\nLines containing '%s':\n", keyword);

    for(int i = 0; i < lines; i++)
    {
        if(strstr(text[i], keyword) != NULL)
        {
            printf("%s\n", text[i]);
        }
    }

    return 0;
}
