#include <stdio.h>

int main()
{
    int indexBlock;
    int blocks[20];
    int n, i;

    printf("----- INDEXED FILE ALLOCATION -----\n");

    printf("Enter index block number: ");
    scanf("%d", &indexBlock);

    printf("Enter number of blocks allocated to file: ");
    scanf("%d", &n);

    printf("Enter block numbers:\n");

    for(i = 0; i < n; i++)
    {
        scanf("%d", &blocks[i]);
    }

    printf("Index Block: %d\n", indexBlock);

    for(i = 0; i < n; i++)
    {
        printf("Index[%d] -> Block %d\n", i, blocks[i]);
    }

    return 0;
}
