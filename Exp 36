#include <stdio.h>

int main()
{
    int blocks[20];
    int n, i;

    printf("----- LINKED FILE ALLOCATION -----\n");

    printf("Enter number of blocks: ");
    scanf("%d", &n);

    printf("Enter block numbers:\n");

    for(i = 0; i < n; i++)
    {
        scanf("%d", &blocks[i]);
    }

    printf("Linked Allocation Structure:\n");

    for(i = 0; i < n - 1; i++)
    {
        printf("%d -> ", blocks[i]);
    }

    printf("%d\n", blocks[n - 1]);

    printf("File blocks linked successfully.\n");

    return 0;
}
