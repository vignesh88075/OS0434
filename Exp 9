#include <stdio.h>
#include <stdlib.h>
#include <sys/ipc.h>
#include <sys/shm.h>
#include <unistd.h>
#include <string.h>
#include <sys/wait.h>

int main()
{
    int shmid = shmget(1234, 1024, 0666 | IPC_CREAT);
    char *str = (char*) shmat(shmid, NULL, 0);

    if(fork() == 0)
    {
        printf("Child: Enter a message: ");
        fgets(str, 1024, stdin);
        printf("Child: Message written to shared memory.\n");
    }
    else
    {
        wait(NULL);
        printf("\nParent: Reading from shared memory...\n");
        printf("Parent: Received message -> %s", str);

        shmdt(str);
        shmctl(shmid, IPC_RMID, NULL);
    }

    return 0;
}
