#include <stdio.h>
int main() {
    int i,j,k,n=5,m=3;
    int alloc[5][3]={{0,1,0},{2,0,0},{3,0,2},{2,1,1},{0,0,2}};
    int max[5][3]={{7,5,3},{3,2,2},{9,0,2},{2,2,2},{4,3,3}};
    int avail[3]={3,3,2};
    int need[5][3],finish[5]={0},safe[5];
    // Need matrix
    for(i=0;i<n;i++)
        for(j=0;j<m;j++)
            need[i][j]=max[i][j]-alloc[i][j];
    // Print Table
    printf("Process  Allocation   Max   Need\n");
    printf("        A B C        A B C  A B C\n");
    for(i=0;i<n;i++){
        printf("P%d      ",i);
        for(j=0;j<m;j++) printf("%d ",alloc[i][j]);
        printf("      ");
        for(j=0;j<m;j++) printf("%d ",max[i][j]);
        printf("   ");
        for(j=0;j<m;j++) printf("%d ",need[i][j]);
        printf("\n");
    }

    // Banker's Algorithm
    int count=0;
    while(count<n){
        for(i=0;i<n;i++){
            if(!finish[i]){
                for(j=0;j<m;j++)
                    if(need[i][j]>avail[j]) break;

                if(j==m){
                    for(k=0;k<m;k++)
                        avail[k]+=alloc[i][k];
                    safe[count++]=i;
                    finish[i]=1;
                }
            }
        }
    }

    // Safe sequence
    printf("\nSafe Sequence: ");
    for(i=0;i<n;i++)
        printf("P%d ",safe[i]);

    return 0;
}
