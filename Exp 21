#include <stdio.h>

int main()
{
    int b[5] = {100, 500, 200, 300, 600}; // memory blocks
    int p[3] = {212, 417, 112};           // processes
    int i, j, worst, allocation[3];

    for(i=0;i<3;i++)
        allocation[i] = -1;

    for(i=0;i<3;i++)
    {
        worst = -1;
        for(j=0;j<5;j++)
        {
            if(b[j] >= p[i])
            {
                if(worst==-1 || b[j] > b[worst])
                    worst = j;
            }
        }

        if(worst != -1)
        {
            allocation[i] = worst;
            b[worst] -= p[i];
        }
    }

    printf("---------------------------------------------\n");
    printf("| Process | Size | Block Allocated |\n");
    printf("---------------------------------------------\n");

    for(i=0;i<3;i++)
    {
        if(allocation[i] != -1)
            printf("|   P%d    | %3d |      B%d        |\n", i+1, p[i], allocation[i]+1);
        else
            printf("|   P%d    | %3d |   Not Allocated |\n", i+1, p[i]);
    }

    printf("---------------------------------------------\n");

    return 0;
}
