#include <stdio.h>

int main()
{
    int frames;
    int pages;

    int reference[50];
    int frame[10];
    int time[10];

    int i, j, k;
    int counter = 0;
    int pageFaults = 0;

    printf("---- LRU PAGE REPLACEMENT ----\n");

    printf("Enter number of frames: ");
    scanf("%d", &frames);

    printf("Enter number of pages: ");
    scanf("%d", &pages);

    printf("Enter reference string:\n");

    for(i = 0; i < pages; i++)
    {
        scanf("%d", &reference[i]);
    }

    for(i = 0; i < frames; i++)
    {
        frame[i] = -1;
        time[i] = 0;
    }

    for(i = 0; i < pages; i++)
    {
        int found = 0;

        for(j = 0; j < frames; j++)
        {
            if(frame[j] == reference[i])
            {
                counter++;
                time[j] = counter;
                found = 1;
                break;
            }
        }

        if(found == 0)
        {
            int least = 0;

            for(j = 1; j < frames; j++)
            {
                if(time[j] < time[least])
                {
                    least = j;
                }
            }

            frame[least] = reference[i];
            counter++;
            time[least] = counter;
            pageFaults++;
        }

        printf("Frames: ");

        for(k = 0; k < frames; k++)
        {
            printf("%d ", frame[k]);
        }

        printf("\n");
    }

    printf("Total Page Faults = %d\n", pageFaults);

    return 0;
}
